{
  // L2 of the Envio 3.2.1 verification loop (scripts/verify-envio-321.sh).
  //
  // Typechecks the PORTED-to-3.2.1 handler surface against the `envio` package
  // types + the codegen type augmentation (.envio/types.d.ts, wired via
  // envio-env.d.ts). The un-ported alpha handlers under src/handlers/ still
  // `import from "generated"` and intentionally do NOT typecheck against 3.2.1
  // types yet — they are EXCLUDED here and added to `include` as each one is
  // ported (the include list grows toward `src/handlers` at finalize).
  //
  // FINALIZE (PR #75, H2): the 31-handler port is complete, so the include list
  // now covers the full ported surface (src/handlers) plus the deploy-path probe.
  // This typechecks every ported handler against config.yaml's codegen output —
  // closing the gap where "L2 tsc 0" only validated the probe handler.
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022"],
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    // skipLibCheck:false would force-check the 1.6MB generated .envio/types.d.ts
    // and all of node_modules; keep it true (same posture as tsconfig.json) so
    // L2 checks OUR ported code against the published envio surface, not envio's
    // own internals.
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "isolatedModules": true,
    "noEmit": true,
    "types": []
  },
  "files": [
    "envio-env.d.ts"
  ],
  "include": [
    "src/handlers",
    "src/probe_handlers"
  ]
}
