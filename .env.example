# To create or update a token visit https://envio.dev/app/api-tokens
ENVIO_API_TOKEN="<YOUR-API-TOKEN>"

# Kitchen upstream API (Envio belt / kitchen-api service) — Bearer token for
# ordering-service probe + ingest. Unset in local dev disables auth unless
# SONAR_KITCHEN_ALLOW_OPEN_AUTH=true.
SERVICE_TOKEN="<YOUR-SERVICE-TOKEN>"

# kitchen-api: Hasura GraphQL for collection status reads
# BELT_GRAPHQL_URL=http://belt-hasura-selfhost.railway.internal:8080/v1/graphql

# kitchen-api: Postgres for ingest job queue (or ENVIO_PG_* belt vars)
# KITCHEN_DATABASE_URL=postgresql://...

# kitchen ingest worker (#112) — polls queued jobs, patches belt config, advances status
# KITCHEN_WORKER_ENABLED=true
# Explicit hermetic/local seam only. Both variables are required. This is not a
# production config/deploy port.
# KITCHEN_PREPARATION_PORT=local_config
# Production intentionally reports preparation unavailable until a durable
# drain/deploy port replaces local_config.
# KITCHEN_BELT_CONFIG_PATH=config.yaml
# KITCHEN_WORKER_INTERVAL_MS=30000
# KITCHEN_INGEST_TIMEOUT_MS=86400000
# Backfill PostgreSQL lock wait; bounded fail-closed instead of hanging forever.
# KITCHEN_BACKFILL_LOCK_TIMEOUT_MS=5000
# KITCHEN_INDEXER_RESTART_WEBHOOK=https://...  # optional Railway redeploy hook
