{
  "name": "envio-indexer",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "tsc --clean",
    "build": "tsc --build",
    "watch": "tsc --watch",
    "codegen": "envio codegen",
    "dev": "envio dev",
    "start": "envio start",
    "test": "vitest run",
    "test:hasura": "vitest run test/hasura-contract",
    "test:gate": "vitest run test/sqd-45-gate-integration.test.ts",
    "test:collection-resolver": "vitest run test/collection-resolver.hermetic.test.ts",
    "test:capability-registry": "vitest run test/capability-registry.hermetic.test.ts",
    "test:bounded-resolver": "vitest run test/bounded-resolver.hermetic.test.ts",
    "test:evm-nft-probe": "vitest run test/evm-nft-probe.hermetic.test.ts",
    "test:metadata-egress": "vitest run test/metadata-egress.hermetic.test.ts test/metadata-egress.browser-boundary.test.ts",
    "pulse": "bash scripts/sonar-pulse.sh",
    "self": "tsx src/self/cli/sonar-self.ts emit",
    "self:check": "tsx src/self/cli/sonar-self.ts check --mode offline",
    "self:write": "tsx src/self/cli/sonar-self.ts write --mode hybrid",
    "cost": "node scripts/railway-cost-model.mjs",
    "verify:belt-config": "node scripts/verify-belt-config.js",
    "verify:belt-contract": "node scripts/verify-belt-contract.mjs",
    "verify:svm-contract": "node scripts/verify-svm-contract.mjs",
    "verify:action-contract": "node scripts/verify-svm-contract.mjs --manifest scripts/action-contract.json",
    "s5:parity-dryrun": "tsx scripts/s5-parity-dryrun.ts",
    "validate:svm-canonical": "tsx scripts/validate-svm-canonical-live.ts",
    "validate:evm-canonical": "tsx scripts/validate-evm-canonical-live.ts",
    "validate:evm-sales": "tsx scripts/validate-evm-sales-live.ts",
    "codegen:mibera": "envio codegen --config config.mibera.yaml",
    "typecheck:mibera": "tsc -p tsconfig.mibera.json",
    "postinstall": "bash scripts/rebuild-events-dist.sh"
  },
  "devDependencies": {
    "@types/node": "20.8.8",
    "@types/pg": "^8.15.4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "dependencies": {
    "@effect/schema": "^0.75.0",
    "@freeside/collection-protocol": "file:./vendor/collection-protocol/freeside-collection-protocol-1.0.0.tgz",
    "@hono/node-server": "^1.14.4",
    "@noble/curves": "^1.7.0",
    "@noble/hashes": "^1.6.0",
    "@solana/web3.js": "^1.98.4",
    "canonicalize": "^2.0.0",
    "effect": "^3.21.0",
    "envio": "3.2.1",
    "ethers": "^6.15.0",
    "hono": "^4.12.23",
    "incur": "^0.4.8",
    "nats": "^2.28.0",
    "pg": "^8.16.0",
    "viem": "^2.21.0"
  },
  "cluster": {
    "eventsPin": {
      "repo": "0xHoneyJar/loa-freeside",
      "subdir": "packages/events",
      "package": "@0xhoneyjar/events",
      "sha": "5d69285a5a01d53f046cff8f24b963a229997b3e"
    }
  },
  "optionalDependencies": {
    "generated": "./generated"
  },
