# Caddyfile — L5 gateway for the freeside-sonar belt factory (S3-T1/T2).
# Listens on Railway's $PORT; reverse-proxies to the belt's L4 GraphQL (BELT_UPSTREAM).
{
	admin off
	# caddy-ratelimit (module compiled in via Dockerfile.gateway)
	order rate_limit before reverse_proxy
	# Railway terminates TLS at its edge + proxies over the private network, so the
	# immediate peer is a Railway proxy IP. Trust private-range peers so {client_ip}
	# resolves the real caller from X-Forwarded-For (else rate-limit keys on the proxy).
	servers {
		trusted_proxies static private_ranges
		client_ip_headers X-Forwarded-For
	}
}

:{$PORT:8080} {
	# S3-T2 / AC-12: bound a single request's size (coarse complexity guard so one query
	# cannot exhaust the indexer). Precise GraphQL depth/cost capping is the documented
	# fast-follow (graphql-armor proxy or Hasura allowlist) — see the S2-T4 deploy runbook.
	request_body {
		max_size 50KB
	}

	# S3-T2 / AC-12: per-IP request rate limit (120 req/min/IP).
	rate_limit {
		zone perip {
			key {client_ip}
			events 120
			window 1m
		}
	}

	# S3-T1 / AC-13: single-config upstream. Swap = change BELT_UPSTREAM + redeploy.
	# Federation-ready: a 2nd belt is an additive route here; the public URL is unchanged.
	reverse_proxy {$BELT_UPSTREAM} {
		header_up Host {upstream_hostport}
	}
}
