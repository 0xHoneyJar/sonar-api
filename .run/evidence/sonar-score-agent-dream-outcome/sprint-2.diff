+        ),
+  event_id: `revocation-${sequence}`,
+  target_kind: "artifact",
+  target_id: targetId,
+  compromised_from: "2026-07-19T04:00:00.000Z",
+  revoked_at: "2026-07-19T04:01:00.000Z",
+  reason: "fixture compromise",
+  issuer_key_id: authority.keyId,
+  epoch,
