+const revocationInput = (
+  sequence: string,
+  targetId = "artifact-1",
+  epoch = "1",
+) => ({
+  schema_version: 1,
+  protocol: TRUTH_CONTRACT_PROTOCOL,
+  environment: "staging",
+  sequence,
+  prior_record_sha256:
+    sequence === "1"
+      ? null
+      : sha256Hex(
+          jcsCanonicalize(
+            compileRevocation(
+              (BigInt(sequence) - 1n).toString(),
+              `artifact-${BigInt(sequence) - 1n}`,
+              epoch,
+            ),
