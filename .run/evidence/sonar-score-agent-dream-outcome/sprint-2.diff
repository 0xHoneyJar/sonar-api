+export const applyTrustRotation = (
+  approvalInput: unknown,
+  bootstrap: TrustBootstrapV1,
+  nextRootHash: string,
+  acceptedAt: TruthIsoTimestamp,
+  store: TrustedGenerationStoreService,
+  compromisedKeyIds: ReadonlySet<string> = new Set(),
